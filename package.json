{
  "name": "true-mem",
  "version": "1.4.1",
  "description": "Persistent memory plugin for OpenCode with cognitive psychology-based memory management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "preversion": "bun run build",
    "build": "bun build src/index.ts --outdir dist --target bun --format esm && tsc --emitDeclarationOnly && bun build src/memory/embedding-worker.ts --outdir dist/memory --target bun --format esm && bun run viewer:build && bun run viewer:server:build",
    "dev": "bun build src/index.ts --outdir dist --target bun --format esm --watch",
    "typecheck": "tsc --noEmit",
    "viewer": "bun run dist/viewer-server/index.js",
    "viewer:dev": "vite --config src/viewer/vite.config.ts",
    "viewer:build": "vite build --config src/viewer/vite.config.ts",
    "viewer:server:build": "bun build src/viewer/server/index.ts --outdir dist/viewer-server --target bun --format esm"
  },
  "keywords": [
    "opencode",
    "ai",
    "memory",
    "plugin",
    "persistent",
    "cognitive",
    "coding-assistant"
  ],
  "author": "rizal72",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rizal72/true-mem.git"
  },
  "bugs": {
    "url": "https://github.com/rizal72/true-mem/issues"
  },
  "homepage": "https://github.com/rizal72/true-mem#readme",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@huggingface/transformers": "^4.0.0-next.1",
    "@opencode-ai/plugin": "^1.2.6",
    "@opencode-ai/sdk": "^1.2.6",
    "chart.js": "^4.5.1",
    "hono": "^4.10.7",
    "preact": "^10.28.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "@types/node": "^25.0.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.22",
    "bun-types": "^1.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "vite": "^7.2.7",
    "typescript": "^5.9.3"
  }
}
